// Prisma schema — Intalva CRM
// Multi-tenant: casi todas las tablas cuelgan de Organization vía organizationId.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth / Organización (multi-tenant)
// ---------------------------------------------------------------------------

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id                  String   @id @default(cuid())
  name                String
  legalName           String?
  taxId               String?
  email               String?
  phone               String?
  website             String?
  logoUrl             String?
  bookingSlug         String?  @unique
  timezone            String   @default("Europe/Madrid")
  defaultVatRate      Decimal  @default(21) @db.Decimal(5, 2)
  iban                String?
  defaultPaymentTerms String?
  entityLabel         String   @default("Expedientes")
  agendaMode          String   @default("RESOURCE")
  address             String?
  postalCode          String?
  city                String?
  province            String?
  country             String   @default("ES")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships      Membership[]
  clients          Client[]
  contacts         Contact[]
  tags             Tag[]
  catalogItems     CatalogItem[]
  appointments     Appointment[]
  events           Event[]
  tasks            Task[]
  scheduleBlocks   ScheduleBlock[]
  budgets          Budget[]
  providers        Provider[]
  expedientes      Expediente[]
  invoices         Invoice[]
  receivedInvoices ReceivedInvoice[]
  moduleSettings   ModuleSetting[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships          Membership[]
  accounts             Account[]
  sessions             Session[]
  appointmentsAsStaff  Appointment[]   @relation("AppointmentProfessional")
  tasksAssigned        Task[]          @relation("TaskAssignee")
  scheduleBlocksOwned  ScheduleBlock[] @relation("ScheduleBlockEmployee")
  budgetsAsSalesperson Budget[]        @relation("BudgetSalesperson")
  expedientesAsOwner   Expediente[]    @relation("ExpedienteResponsible")
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(MEMBER)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

// Modelos estándar de Auth.js (para OAuth futuro, ej. Google Calendar en Fase 3)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Clientes / Contactos / Etiquetas
// ---------------------------------------------------------------------------

model Client {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isCompany            Boolean      @default(false)
  firstName            String
  lastName             String?
  taxId                String?
  clientCode           String?
  birthDate            DateTime?
  mobilePhone          String?
  landlinePhone        String?
  email                String?
  address              String?
  postalCode           String?
  city                 String?
  province             String?
  region               String?
  country              String       @default("ES")
  notes                String?
  whatsappOptIn        Boolean      @default(true)
  equivalenceSurcharge Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tags         ClientTag[]
  contacts     Contact[]
  appointments Appointment[]
  budgets      Budget[]
  invoices     Invoice[]
  expedientes  Expediente[]

  @@index([organizationId])
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  company        String?
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Tag {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String       @default("#64748b")

  clients ClientTag[]

  @@unique([organizationId, name])
}

model ClientTag {
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
}

// ---------------------------------------------------------------------------
// Catálogo
// ---------------------------------------------------------------------------

enum CatalogItemType {
  SERVICIO
  PRODUCTO
  EXTRA
}

model CatalogItem {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type            CatalogItemType @default(SERVICIO)
  name            String
  durationMinutes Int?
  bufferMinutes   Int?
  basePrice       Decimal         @default(0) @db.Decimal(10, 2)
  vatRate         Decimal         @default(21) @db.Decimal(5, 2)
  active          Boolean         @default(true)
  allowedTimes    String[]
  maxPerSlot      Int?
  conditions      String?
  sku             String?
  stock           Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  appointments Appointment[]
  budgetLines  BudgetLine[]
  invoiceLines InvoiceLine[]

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Agenda: Cita / Reunión-Evento / Tarea / Bloqueo de horario
// ---------------------------------------------------------------------------

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

model Appointment {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalogItemId   String?
  catalogItem     CatalogItem?      @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  professionalId  String?
  professional    User?             @relation("AppointmentProfessional", fields: [professionalId], references: [id], onDelete: SetNull)
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  startsAt        DateTime
  durationMinutes Int               @default(60)
  location        String?
  videoCallUrl    String?
  notes           String?
  status          AppointmentStatus @default(PENDIENTE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId, startsAt])
}

model Event {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title               String
  allDay              Boolean      @default(false)
  startsAt            DateTime
  durationMinutes     Int          @default(60)
  staffUserIds        String[]
  externalGuestEmails String[]
  location            String?
  videoCallUrl        String?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([organizationId, startsAt])
}

model Task {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  allDay          Boolean      @default(false)
  startsAt        DateTime
  durationMinutes Int          @default(60)
  assigneeId      String?
  assignee        User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  notes           String?
  completed       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, startsAt])
}

enum ScheduleBlockScope {
  EMPLEADO
  NEGOCIO
}

model ScheduleBlock {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scope          ScheduleBlockScope @default(EMPLEADO)
  employeeId     String?
  employee       User?              @relation("ScheduleBlockEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  date           DateTime           @db.Date
  startTime      String
  endTime        String
  reason         String?
  createdAt      DateTime           @default(now())

  @@index([organizationId, date])
}

// ---------------------------------------------------------------------------
// Presupuestos
// ---------------------------------------------------------------------------

enum BudgetStatus {
  BORRADOR
  ENVIADO
  ACEPTADO
  RECHAZADO
  CADUCADO
}

model Budget {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  number         String?
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  validUntil     DateTime?
  irpfRate       Decimal      @default(0) @db.Decimal(5, 2)
  salespersonId  String?
  salesperson    User?        @relation("BudgetSalesperson", fields: [salespersonId], references: [id], onDelete: SetNull)
  paymentTerms   String?
  notes          String?
  discountPct    Decimal      @default(0) @db.Decimal(5, 2)
  status         BudgetStatus @default(BORRADOR)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines   BudgetLine[]
  invoice Invoice?

  @@index([organizationId])
}

model BudgetLine {
  id            String       @id @default(cuid())
  budgetId      String
  budget        Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  description   String
  quantity      Decimal      @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal      @default(0) @db.Decimal(10, 2)
  discountPct   Decimal      @default(0) @db.Decimal(5, 2)
  vatRate       Decimal      @default(21) @db.Decimal(5, 2)
  sortOrder     Int          @default(0)
}

// ---------------------------------------------------------------------------
// Proveedores / Expedientes
// ---------------------------------------------------------------------------

model Provider {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  taxId          String?
  email          String?
  phone          String?
  address        String?
  postalCode     String?
  city           String?
  province       String?
  country        String       @default("ES")
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  receivedInvoices ReceivedInvoice[]

  @@index([organizationId])
}

enum ExpedienteStatus {
  ABIERTO
  EN_PROCESO
  CERRADO
}

model Expediente {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name           String
  number         String?
  type           String?
  vatRegime      String?
  taxModels      String[]
  periodicity    String?
  ownerTaxId     String?
  responsibleId  String?
  responsible    User?            @relation("ExpedienteResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  status         ExpedienteStatus @default(ABIERTO)
  description    String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Facturación (emitidas / recibidas)
// ---------------------------------------------------------------------------

enum InvoiceType {
  SIMPLIFICADA
  COMPLETA
}

enum InvoiceStatus {
  BORRADOR
  EMITIDA
  PAGADA
  VENCIDA
}

// Estado del envío del registro de facturación a la AEAT. El registro y el
// QR ya se generan con el formato oficial en cuanto se emite la factura,
// pero el envío real requiere un certificado digital que la organización
// todavía no tiene — ver src/lib/verifactu.ts.
enum VerifactuSubmissionStatus {
  NO_CONFIGURADO
  PENDIENTE_ENVIO
  ENVIADO
  ERROR
}

model Invoice {
  id                        String                    @id @default(cuid())
  organizationId            String
  organization              Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  number                    String?
  clientId                  String?
  client                    Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  budgetId                  String?                   @unique
  budget                    Budget?                   @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  type                      InvoiceType               @default(SIMPLIFICADA)
  irpfRate                  Decimal                   @default(0) @db.Decimal(5, 2)
  dueDate                   DateTime?
  discountPct               Decimal                   @default(0) @db.Decimal(5, 2)
  status                    InvoiceStatus             @default(BORRADOR)
  paidAt                    DateTime?
  // Verifactu: registro de facturación con el formato oficial AEAT
  // (RD 1007/2023), calculado localmente. verifactuHash es la Huella
  // encadenada oficial (reemplaza el hash casero anterior); verifactuRecord
  // guarda el registro completo (RegistroAlta) listo para enviar el día que
  // haya certificado digital.
  verifactuHash             String?
  verifactuPrevHash         String?
  verifactuQrData           String?
  verifactuRecord           Json?
  verifactuQrUrl            String?
  verifactuSubmissionStatus VerifactuSubmissionStatus @default(NO_CONFIGURADO)
  verifactuSubmissionError  String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  lines InvoiceLine[]

  @@index([organizationId])
}

model InvoiceLine {
  id            String       @id @default(cuid())
  invoiceId     String
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  description   String
  quantity      Decimal      @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal      @default(0) @db.Decimal(10, 2)
  discountPct   Decimal      @default(0) @db.Decimal(5, 2)
  vatRate       Decimal      @default(21) @db.Decimal(5, 2)
  sortOrder     Int          @default(0)
}

enum ReceivedInvoiceStatus {
  PENDIENTE_VERIFICACION
  VERIFICADA
}

enum ReceivedInvoiceSource {
  SUBIDA
  EMAIL
  MANUAL
}

model ReceivedInvoice {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerId     String?
  provider       Provider?             @relation(fields: [providerId], references: [id], onDelete: SetNull)
  invoiceNumber  String?
  invoiceDate    DateTime?
  baseAmount     Decimal               @default(0) @db.Decimal(10, 2)
  vatAmount      Decimal               @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal               @default(0) @db.Decimal(10, 2)
  status         ReceivedInvoiceStatus @default(PENDIENTE_VERIFICACION)
  source         ReceivedInvoiceSource @default(MANUAL)
  fileUrl        String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  lines ReceivedInvoiceLine[]

  @@index([organizationId])
}

model ReceivedInvoiceLine {
  id                String          @id @default(cuid())
  receivedInvoiceId String
  receivedInvoice   ReceivedInvoice @relation(fields: [receivedInvoiceId], references: [id], onDelete: Cascade)
  productName       String
  sku               String?
  quantity          Decimal         @default(1) @db.Decimal(10, 2)
  unit              String?
  unitPrice         Decimal         @default(0) @db.Decimal(10, 2)
  total             Decimal         @default(0) @db.Decimal(10, 2)
}

// ---------------------------------------------------------------------------
// Configuración de módulos (activar/desactivar por organización)
// ---------------------------------------------------------------------------

model ModuleSetting {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleKey      String
  enabled        Boolean      @default(true)

  @@unique([organizationId, moduleKey])
}
